-- VR Size & Physics Gun ClientScript (Starts Toggled Off)
-- Place in StarterPlayerScripts or StarterCharacterScripts

local VRService = game:GetService("VRService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera
local playerGui = player:WaitForChild("PlayerGui") -- Added PlayerGui reference

-- --- CONFIGURATION CONFIG ---
local MAX_RAYCAST_DISTANCE = 10000 
local TRACKING_SPEED = 9 
local DISTANCE_CHANGE_SPEED = 20 
local SCALE_SPEED = 0.015 

-- Visuals
local COLOR_WHITE_BEAM = Color3.fromRGB(255, 255, 255)       

-- Master switch starts as FALSE (Disabled)
local IS_SCRIPT_ENABLED = false 

-- State Variables
local isHolding = false
local targetPart = nil
local currentScale = 1.0
local holdDistance = 0

-- Effects Instances
local handAttachment = nil
local targetAttachment = nil
local visualBeam = nil
local currentHighlight = nil
local scaleGui = nil
local scaleText = nil

-- Torso Menu UI References
local torsoMenuPart = nil
local torsoMenuGui = nil
local toggleButton = nil

-- Helper: Get Right Hand CFrame
local function getRightHandWorldCFrame()
    local handCFrame = VRService:GetUserCFrame(Enum.UserCFrame.RightHand)
    return camera.CFrame * handCFrame
end

-- Create the floating text display above targets
local function createScaleIndicator(parentInstance)
    if scaleGui then scaleGui:Destroy() end
    
    scaleGui = Instance.new("BillboardGui")
    scaleGui.Size = UDim2.new(0, 100, 0, 50)
    scaleGui.StudsOffset = Vector3.new(0, 2, 0)
    scaleGui.AlwaysOnTop = true
    
    scaleText = Instance.new("TextLabel")
    scaleText.Size = UDim2.new(1, 0, 1, 0)
    scaleText.BackgroundTransparency = 1
    scaleText.TextColor3 = Color3.fromRGB(255, 255, 255)
    scaleText.TextSize = 24
    scaleText.Font = Enum.Font.SourceSansBold
    scaleText.TextStrokeTransparency = 1
    scaleText.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    scaleText.Text = string.format("x%.2f", currentScale)
    scaleText.Parent = scaleGui
    
    scaleGui.Parent = parentInstance
end

-- Create highlight effect
local function applyHighlight(target)
    if currentHighlight then currentHighlight:Destroy() end
    
    currentHighlight = Instance.new("Highlight")
    currentHighlight.FillColor = COLOR_WHITE_BEAM
    currentHighlight.FillTransparency = 0.85
    currentHighlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    currentHighlight.OutlineTransparency = 0.3
    
    local targetInstance = target:FindFirstAncestorOfClass("Model") or target
    currentHighlight.Parent = targetInstance
end

-- Create white visual beam effects directly from the Right Arm position
local function createBeam(part, hitPosition)
    if visualBeam then visualBeam:Destroy() end
    if handAttachment then handAttachment:Destroy() end
    if targetAttachment then targetAttachment:Destroy() end
    
    handAttachment = Instance.new("Attachment")
    handAttachment.Parent = workspace.Terrain
    
    targetAttachment = Instance.new("Attachment")
    targetAttachment.Parent = part
    targetAttachment.WorldPosition = hitPosition 
    
    visualBeam = Instance.new("Beam")
    visualBeam.Attachment0 = handAttachment
    visualBeam.Attachment1 = targetAttachment
    visualBeam.Color = ColorSequence.new(COLOR_WHITE_BEAM)
    visualBeam.Width0 = 0.015
    visualBeam.Width1 = 0.015
    visualBeam.FaceCamera = true
    visualBeam.Parent = workspace.Terrain
end

local function cleanupRayAndVisuals()
    isHolding = false
    targetPart = nil
    currentScale = 1.0
    
    if visualBeam then visualBeam:Destroy() visualBeam = nil end
    if handAttachment then handAttachment:Destroy() end
    if targetAttachment then targetAttachment:Destroy() end
    if currentHighlight then currentHighlight:Destroy() currentHighlight = nil end
    if scaleGui then scaleGui:Destroy() scaleGui = nil end
end

-- Raycast scan logic targeting unanchored baseparts starting from Right Arm layout
local function scanForTarget()
    local handCF = getRightHandWorldCFrame()
    local rayOrigin = handCF.Position
    local rayDirection = handCF.LookVector * MAX_RAYCAST_DISTANCE
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    if player.Character then
        raycastParams.FilterDescendantsInstances = {player.Character}
    end
    
    local raycastResult = workspace:Raycast(rayOrigin, rayDirection, raycastParams)
     
    if raycastResult and raycastResult.Instance then
        local hitInstance = raycastResult.Instance
        if hitInstance:IsA("BasePart") and not hitInstance.Anchored then
            return hitInstance, raycastResult.Position
        end
    end
    return nil, nil
end

-- Math-safe scaling system
local function adjustScale(part, factor)
    if not part then return end
    
    currentScale = math.clamp(currentScale * factor, 0.05, 15.0) 
    
    local targetModel = part:FindFirstAncestorOfClass("Model")
    if targetModel then
        if not targetModel.PrimaryPart then
            targetModel.PrimaryPart = part
        end
        targetModel:ScaleTo(currentScale)
    else
        part.Size = part.Size * factor
    end
    
    if scaleText then
        scaleText.Text = string.format("x%.2f", currentScale)
    end
end

-- --- PHYSICAL TORSO MENU CREATION ---
local function updateButtonVisuals()
    if not toggleButton then return end
    if IS_SCRIPT_ENABLED then
        toggleButton.BackgroundColor3 = Color3.fromRGB(40, 180, 100) -- Flat Green
        toggleButton.Text = "Resizer: ON"
    else
        toggleButton.BackgroundColor3 = Color3.fromRGB(74, 114, 153) -- Flat Red
        toggleButton.Text = "Resizer: OFF"
    end
end

local function toggleScriptState()
    IS_SCRIPT_ENABLED = not IS_SCRIPT_ENABLED
    updateButtonVisuals()
    if not IS_SCRIPT_ENABLED then
        cleanupRayAndVisuals()
    end
end

local function setupTorsoMenu(character)
    if torsoMenuPart then torsoMenuPart:Destroy() end
    
    local torso = character:WaitForChild("UpperTorso", 0.1) or character:WaitForChild("Torso", 0.1)
    if not torso then return end
    
    -- Creating physical menu anchor part
    torsoMenuPart = Instance.new("Part")
    torsoMenuPart.Name = "VRTorsoMenuPart"
    torsoMenuPart.Size = Vector3.new(1.6, 0.5, 0.1) 
    torsoMenuPart.Transparency = 1
    
    -- Patched to match your working script settings:
    torsoMenuPart.Massless = true
    torsoMenuPart.CanCollide = false
    torsoMenuPart.CanQuery = false -- MATCHED TO FIXED SCRIPT
    torsoMenuPart.CanTouch = false
    torsoMenuPart.Parent = character
    
    local weld = Instance.new("Weld")
    weld.Part0 = torso
    weld.Part1 = torsoMenuPart
    weld.C0 = CFrame.new(-2, 0.985, -6.1) -- MATCHED TO FIXED SCRIPT POSITION (-3 studs out)
    weld.Parent = torsoMenuPart
    
    -- UI set up identically to your working configuration
    torsoMenuGui = Instance.new("SurfaceGui")
    torsoMenuGui.Name = "VRTorsoMenuGui"
    torsoMenuGui.Face = Enum.NormalId.Back -- MATCHED TO FIXED SCRIPT
    torsoMenuGui.AlwaysOnTop = true
    torsoMenuGui.ResetOnSpawn = false
    torsoMenuGui.CanvasSize = Vector2.new(400, 150) -- MATCHED TO FIXED SCRIPT
    torsoMenuGui.Enabled = false
    torsoMenuGui.Adornee = torsoMenuPart -- MATCHED TO FIXED SCRIPT
    torsoMenuGui.Parent = playerGui -- MATCHED TO FIXED SCRIPT (Crucial for VR tracking!)
    
    toggleButton = Instance.new("TextButton")
    toggleButton.Size = UDim2.new(1, 0, 1, 0)
    toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggleButton.TextSize = 36
    toggleButton.Font = Enum.Font.SourceSansBold
    toggleButton.Parent = torsoMenuGui
    
    local uiCorner = Instance.new("UICorner")
    uiCorner.CornerRadius = UDim.new(0, 16)
    uiCorner.Parent = toggleButton
    
    updateButtonVisuals()
    
    toggleButton.MouseButton1Click:Connect(function()
        toggleScriptState()
    end)
end

player.CharacterAdded:Connect(setupTorsoMenu)
if player.Character then
    setupTorsoMenu(player.Character)
end

--- --- CONTROLLER INPUT HANDLING ---
UserInputService.InputBegan:Connect(function(input, processed)
    -- X Button toggles display visibility
    if input.KeyCode == Enum.KeyCode.ButtonL3 then
        if torsoMenuGui and torsoMenuPart then
            -- Toggle the GUI screen
            torsoMenuGui.Enabled = not torsoMenuGui.Enabled
            
            -- If the GUI is enabled, make the part visible (0). Otherwise, hide it (1).
            if torsoMenuGui.Enabled then
                torsoMenuPart.Transparency = 0 -- Fully visible when open
            else
                torsoMenuPart.Transparency = 1 -- Completely invisible when closed
            end
        end
        return
    end

    if not IS_SCRIPT_ENABLED then return end

    if input.KeyCode == Enum.KeyCode.ButtonR2 then
        if not isHolding then
            local character = player.Character
            local rightArm = character and character:FindFirstChild("Right Arm")
            
            if rightArm then
                local part, hitPos = scanForTarget()
                if part then
                    targetPart = part
                    isHolding = true
                    holdDistance = (getRightHandWorldCFrame().Position - hitPos).Magnitude
                     
                    createBeam(part, hitPos)
                    applyHighlight(part)
                    createScaleIndicator(part)
                end
            end
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.ButtonR2 then
        cleanupRayAndVisuals()
    end
end)

-- --- MAIN TRACKING & PHYSICS LOOP ---
RunService.RenderStepped:Connect(function(deltaTime)
    if not IS_SCRIPT_ENABLED then
        cleanupRayAndVisuals()
        return
    end
    
    local character = player.Character
    local rightArm = character and character:FindFirstChild("Right Arm")
    
    if not rightArm then
        cleanupRayAndVisuals()
        return
    end
    
    local handCF = getRightHandWorldCFrame()
    
    if isHolding and targetPart and targetPart.Parent then
        local gamepadState = UserInputService:GetGamepadState(Enum.UserInputType.Gamepad1)
        
        for _, state in ipairs(gamepadState) do
            if state.KeyCode == Enum.KeyCode.Thumbstick2 then
                local yValue = state.Position.Y
                if math.abs(yValue) > 0.1 then 
                    holdDistance = holdDistance - (yValue * DISTANCE_CHANGE_SPEED * deltaTime)
                    holdDistance = math.clamp(holdDistance, 2, MAX_RAYCAST_DISTANCE)
                end
            end
            
            if state.KeyCode == Enum.KeyCode.ButtonA and state.UserInputState == Enum.UserInputState.Begin then
                adjustScale(targetPart, 1 - SCALE_SPEED)
            end
            
            if state.KeyCode == Enum.KeyCode.ButtonB and state.UserInputState == Enum.UserInputState.Begin then
                adjustScale(targetPart, 1 + SCALE_SPEED)
            end
        end
        
        if handAttachment then
            handAttachment.WorldPosition = handCF.Position
            handAttachment.CFrame = handCF
        end
        
        local targetPosition = handCF.Position + (handCF.LookVector * holdDistance)
        local currentPos = targetPart.Position
        local velocityNeeded = (targetPosition - currentPos) * TRACKING_SPEED
        
        targetPart.AssemblyLinearVelocity = velocityNeeded
        targetPart.AssemblyAngularVelocity = targetPart.AssemblyAngularVelocity * 0.9 
         
        if visualBeam and targetAttachment then
            local lagVector = currentPos - targetPosition
            local lagDistance = lagVector.Magnitude
            
            if lagDistance > 0.5 then
                local localLag = handCF:VectorToObjectSpace(lagVector)
                visualBeam.CurveSize0 = localLag.X * 0.5
                visualBeam.CurveSize1 = -localLag.Y * 0.5
            else
                visualBeam.CurveSize0 = 0
                visualBeam.CurveSize1 = 0
            end
        end
    end
end)
