-- 6. DYNAMIC GMOD INTERACTION & RENDERING
-- ==========================================
local currentActiveButton = nil

local function loadCategory(categoryName, categoryButton)
	if currentActiveButton then
		currentActiveButton.BackgroundColor3 = Color3.fromRGB(56, 56, 56)
		currentActiveButton.BackgroundTransparency = 0.3
		currentActiveButton.TextColor3 = Color3.fromRGB(220, 220, 220)
	end
	currentActiveButton = categoryButton
	currentActiveButton.BackgroundColor3 = Color3.fromRGB(74, 114, 153)
	currentActiveButton.BackgroundTransparency = 0.1
	currentActiveButton.TextColor3 = Color3.fromRGB(255, 255, 255)

	for _, child in ipairs(contentFrame:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end
	
	local modelsInFolder = CategoriesData[categoryName]
	if not modelsInFolder then return end
	
	for _, childObj in ipairs(modelsInFolder) do
		local propTile = Instance.new("TextButton")
		propTile.Size = UDim2.new(0, 90, 0, 90)
		propTile.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
		propTile.BackgroundTransparency = 0.2
		propTile.BorderColor3 = Color3.fromRGB(255, 255, 255)
		propTile.BorderSizePixel = 0
		propTile.Text = ""
		propTile.ZIndex = 3
		propTile.Parent = contentFrame
		
		local tileStroke = Instance.new("UIStroke")
		tileStroke.Thickness = 1
		tileStroke.Color = Color3.fromRGB(255, 255, 255)
		tileStroke.Transparency = 0.85
		tileStroke.Parent = propTile
		
		local tileCorner = Instance.new("UICorner")
		tileCorner.CornerRadius = UDim.new(0, 6)
		tileCorner.Parent = propTile

		local viewFrame = Instance.new("ViewportFrame")
		viewFrame.Size = UDim2.new(1, 0, 1, -18) 
		viewFrame.Position = UDim2.new(0, 0, 0, 0)
		viewFrame.BackgroundTransparency = 1
		viewFrame.ZIndex = 4
		viewFrame.Parent = propTile
		
		local previewObj = childObj:Clone()
		if previewObj:IsA("Model") then
			previewObj:PivotTo(CFrame.new(0, 0, 0))
		elseif previewObj:IsA("BasePart") then
			previewObj.CFrame = CFrame.new(0, 0, 0)
		end
		previewObj.Parent = viewFrame
		
		local previewCam = Instance.new("Camera")
		viewFrame.CurrentCamera = previewCam
		previewCam.Parent = viewFrame
		
		local currentCF, currentSize
		if childObj:IsA("Model") then
			currentCF, currentSize = childObj:GetBoundingBox()
		else
			currentCF = childObj.CFrame
			currentSize = childObj.Size
		end
		
		local distance = math.max(currentSize.X, currentSize.Y, currentSize.Z) * 1.4
		previewCam.CFrame = CFrame.new(Vector3.new(distance, distance * 0.8, distance), Vector3.new(0, 0, 0))

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(1, -4, 0, 14)
		nameLabel.Position = UDim2.new(0, 2, 1, -16)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Text = childObj.Name
		nameLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
		nameLabel.Font = Enum.Font.SourceSans
		nameLabel.TextSize = 10 
		nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
		nameLabel.ZIndex = 4
		nameLabel.Parent = propTile

		propTile.MouseEnter:Connect(function()
			propTile.BackgroundColor3 = Color3.fromRGB(74, 114, 153)
			tileStroke.Transparency = 0.5
		end)
		propTile.MouseLeave:Connect(function()
			propTile.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
			tileStroke.Transparency = 0.85
		end)
		
		propTile.MouseButton1Click:Connect(function()
			spawnModel(categoryName, childObj.Name)
		end)
	end
	
	task.wait()
	contentFrame.CanvasSize = UDim2.new(0, 0, 0, gridLayout.AbsoluteContentSize.Y + 15)
end

local function generateSidebarUI()
	for _, child in ipairs(sidebarFrame:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end

	local firstCategoryName = nil
	local firstCategoryBtn = nil

	for categoryName, _ in pairs(CategoriesData) do
		if not firstCategoryName then firstCategoryName = categoryName end

		local catBtn = Instance.new("TextButton")
		catBtn.Size = UDim2.new(1, 0, 0, 28)
		catBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
		catBtn.BackgroundTransparency = 0.3
		catBtn.BorderSizePixel = 0
		catBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
		catBtn.Text = "  " .. categoryName
		catBtn.Font = Enum.Font.SourceSans
		catBtn.TextSize = 13
		catBtn.TextXAlignment = Enum.TextXAlignment.Left
		catBtn.ZIndex = 3
		catBtn.Parent = sidebarFrame
		
		local catCorner = Instance.new("UICorner")
		catCorner.CornerRadius = UDim.new(0, 4)
		catCorner.Parent = catBtn
		
		if not firstCategoryBtn then firstCategoryBtn = catBtn end

		catBtn.MouseEnter:Connect(function()
			if currentActiveButton ~= catBtn then
				catBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
				catBtn.BackgroundTransparency = 0.1
			end
		end)
		catBtn.MouseLeave:Connect(function()
			if currentActiveButton ~= catBtn then
				catBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
				catBtn.BackgroundTransparency = 0.3
			end
		end)

		catBtn.MouseButton1Click:Connect(function()
			loadCategory(categoryName, catBtn)
		end)
	end
	
	sidebarFrame.CanvasSize = UDim2.new(0, 0, 0, sidebarLayout.AbsoluteContentSize.Y)

	if firstCategoryName and firstCategoryBtn then
		loadCategory(firstCategoryName, firstCategoryBtn)
	end
end

