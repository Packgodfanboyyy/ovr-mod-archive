-- Asset Extraction
local function loadAndIndexPropsStorage()
	title.Text = "OVR's Mod Spawn Menu (Loading...)"
	local success, objects = pcall(function()
		return game:GetObjects("rbxassetid://" .. PROPS_FOLDER_ASSET_ID)
	end)
	
	if success and objects and objects[1] then
		PropsStorage = objects[1]
		
		for _, folder in ipairs(PropsStorage:GetChildren()) do
			if folder:IsA("Folder") or folder:IsA("Model") then
				CategoriesData[folder.Name] = {}
				for _, prop in ipairs(folder:GetChildren()) do
					table.insert(CategoriesData[folder.Name], prop)
				end
			end
		end
		
		title.Text = "OVR's Mod Spawn Menu"
		generateSidebarUI()
	else
		title.Text = "OVR's Mod Spawn Menu (Error Loading!)"
	end
end

task.spawn(loadAndIndexPropsStorage)
