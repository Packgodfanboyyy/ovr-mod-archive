-- ==========================================
-- 3. CORE SPAWN LOGIC
-- ==========================================
local function spawnModel(categoryName, modelName)
    local character = player.Character
    if not character then return end
    
    local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    if not torso then return end
    
    if not PropsStorage then return end
    
    local categoryFolder = PropsStorage:FindFirstChild(categoryName)
    local sourceModel = categoryFolder and categoryFolder:FindFirstChild(modelName)
    
    if sourceModel then
        local model = sourceModel:Clone()
        
        if model:IsA("BasePart") then
            model.Anchored = false
        end
     
        for _, descendant in ipairs(model:GetDescendants()) do
            if descendant:IsA("BasePart") then
                descendant.Anchored = false
            end
        end

        model.Parent = workspace
        
        local spawnPosition = torso.CFrame * CFrame.new(0, 0, -10)
        local rotationOffset = CFrame.Angles(-90, math.rad(0), 180)
        local finalCFrame = spawnPosition * rotationOffset
        
        if model:IsA("Model") then
            model:PivotTo(finalCFrame)
        elseif model:IsA("BasePart") then
            model.CFrame = finalCFrame
        end
    end
end

