local function setupMenuPart(character)
	if menuPart then menuPart:Destroy() end
	
	menuPart = Instance.new("Part")
	menuPart.Name = "VR_MenuDisplayPart"
	menuPart.Size = Vector3.new(4.4, 3.2, 0.05) 
	
	-- Physical Glass Blur: Keeping the material as glass so anything in the game world behind it gets blurred!
	menuPart.Transparency = 1
	menuPart.Material = Enum.Material.Glass
	menuPart.Color = Color3.fromRGB(30, 30, 35)
	
	menuPart.CanCollide = false  
	menuPart.Massless = true     
	menuPart.CanQuery = false    
	menuPart.CanTouch = false
	menuPart.Anchored = true     
	menuPart.Parent = workspace

	surfaceGui.Adornee = menuPart
end

